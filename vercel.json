{
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/app/node_modules/@expo/vector-icons/:path*", "destination": "/app/assets/node_modules/@expo/vector-icons/:path*" },
    { "source": "/app/node_modules/@react-navigation/:path*", "destination": "/app/assets/node_modules/@react-navigation/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
